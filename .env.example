# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Personalizes Tacit to speak as your digital twin
USER_NAME=Your Name
USER_ROLE=Your Role
USER_ORGANIZATION=Your Organization

# Optional overrides (defaults shown)
# HOST=127.0.0.1
# PORT=8000
# DEBUG=true

# Transcription settings
WHISPER_MODEL=base  # Options: tiny, base, small, medium, large-v1, large-v2, large-v3
TIKTOK_COOKIES_B64=  # Base64-encoded Netscape format cookies for authenticated TikTok requests
X_COOKIES_B64=  # Base64-encoded Netscape format cookies for authenticated X/Twitter requests (age-gated/protected tweets, and REQUIRED for X Article rendering below — confirmed live that anonymous visitors get a sign-in wall on Articles specifically, unlike most regular tweets)
YT_DLP_RETRIES=3  # Number of retry attempts for yt-dlp downloads
TWEET_PLAYWRIGHT_FALLBACK=false  # Render Chromium for regular tweets oEmbed/yt-dlp can't read (protected posts, media-only tweets with no video). OFF by default — appears to OOM-crash low-memory instances. Only enable after confirming headroom.
X_ARTICLE_PLAYWRIGHT_FALLBACK=true  # Render Chromium specifically for x.com/i/article/ URLs (X's long-form post format) — no non-browser extraction path exists for these at all. ON by default (narrower blast radius than TWEET_PLAYWRIGHT_FALLBACK since it only fires for this one URL shape), but carries the same Chromium memory cost per request — set to false to disable if issues arise. Needs X_COOKIES_B64 set to actually succeed (see above).

# Residential proxy for YouTube/TikTok (REQUIRED in production — YouTube blocks datacenter IPs).
# Easiest: Webshare residential — just paste username + password (rotating endpoint auto-built):
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Or any other residential proxy as a full URL (http://user:pass@host:port):
YOUTUBE_PROXY_URL=
