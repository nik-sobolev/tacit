# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Personalizes Tacit to speak as your digital twin
USER_NAME=Your Name
USER_ROLE=Your Role
USER_ORGANIZATION=Your Organization

# Optional overrides (defaults shown)
# HOST=127.0.0.1
# PORT=8000
# DEBUG=true

# Transcription settings
WHISPER_MODEL=base  # Options: tiny, base, small, medium, large-v1, large-v2, large-v3
TIKTOK_COOKIES_B64=  # Base64-encoded Netscape format cookies for authenticated TikTok requests
YT_DLP_RETRIES=3  # Number of retry attempts for yt-dlp downloads

# Residential proxy for YouTube/TikTok (REQUIRED in production — datacenter IPs are blocked by YouTube).
# Format: http://user:pass@host:port  e.g. Webshare rotating residential endpoint.
YOUTUBE_PROXY_URL=
