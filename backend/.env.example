# Tacit Environment Variables

# Anthropic API (chat)
ANTHROPIC_API_KEY=your_api_key_here

# Gemini API (node title/summary/key_points enrichment — cheaper than Claude for
# this structured-extraction task). Get a free key at aistudio.google.com/apikey.
# Falls back to Claude automatically if left blank.
GEMINI_API_KEY=your_gemini_api_key_here
# SUMMARIZATION_PROVIDER=claude   # uncomment to force Claude even with a Gemini key set

# Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite:///./data/tacit.db
CHROMA_PERSIST_DIR=./data/chroma

# User Configuration
# IMPORTANT: Customize these with YOUR information
USER_NAME=User
USER_ROLE=Executive
USER_ORGANIZATION=Organization

# Storage — set to the Render persistent disk mount path to survive redeploys
# DATA_DIR=/var/data
