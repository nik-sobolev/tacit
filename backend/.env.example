# Tacit Environment Variables

# Anthropic API
ANTHROPIC_API_KEY=your_api_key_here

# Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite:///./data/tacit.db
CHROMA_PERSIST_DIR=./data/chroma

# User Configuration
# IMPORTANT: Customize these with YOUR information
USER_NAME=User
USER_ROLE=Executive
USER_ORGANIZATION=Organization
