{
  "manifest_version": 3,
  "name": "Save to Tacit",
  "version": "1.0.1",
  "description": "Clip any page to your Tacit account in one click — even pages that need you to be logged in to view.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.trytacit.app/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Tacit",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
